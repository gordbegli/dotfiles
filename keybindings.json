[
  // ⌥⌘C: Toggle Case-Sensitive Search
  // ⌥⌘W: Toggle Search for Whole Word
  { "key": "cmd+e", "command": "workbench.action.debug.continue", "when": "inDebugMode" },
  { "key": "cmd+l", "command": "workbench.action.debug.stepOver", "when": "inDebugMode" },
  { "key": "cmd+j", "command": "workbench.action.debug.stepInto", "when": "inDebugMode" },
  { "key": "cmd+k", "command": "workbench.action.debug.stepOut", "when": "inDebugMode" },
  { "key": "cmd+r", "command": "workbench.action.debug.restart", "when": "inDebugMode" },
  { "key": "alt+escape", "command": "workbench.action.debug.stop", "when": "inDebugMode" },
  { "key": "alt+d", "command": "workbench.action.debug.start"},
  { "key": "alt+b", "command": "editor.debug.action.toggleBreakpoint" },
  { "key": "alt+w", "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup", "when": "!inEditorsPicker" },
  { "key": "shift+cmd+[", "command": "workbench.action.previousEditor" },
  { "key": "shift+cmd+]", "command": "workbench.action.nextEditor" },
  { "key": "shift+alt+[", "command": "workbench.action.terminal.focusPreviousPane" },
  { "key": "shift+alt+]", "command": "workbench.action.terminal.focusNextPane" },
  { "key": "cmd+shift+d", "command": "workbench.action.splitEditorDown" },
  { "key": "cmd+d", "command": "workbench.action.splitEditorRight" },
  { "key": "cmd+shift+enter", "command": "workbench.action.toggleMaximizeEditorGroup" }
]