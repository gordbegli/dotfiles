{
    "git.openRepositoryInParentFolders": "never",
    "[typescriptreact]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "explorer.confirmDelete": false,
    "extensions.ignoreRecommendations": true,
    "window.confirmBeforeClose": "always",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.tabSize": 2,
    "diffEditor.renderSideBySide": false,
    "git.blame.editorDecoration.enabled": false,
    "git.blame.statusBarItem.enabled": true,
    "workbench.startupEditor": "none",
    "workbench.colorCustomizations": {
        "terminal.findMatchBackground": "#FF0000",
        "terminal.findMatchBorder": "#FF0000",
        "terminal.findMatchHighlightBackground": "#00FF00",
        "terminal.findMatchHighlightBorder": "#00FF00",
        "terminalOverviewRuler.findMatchForeground": "#FF0000",
        "editorError.foreground": "#00000000",
        "editorWarning.foreground": "#00000000",
        "editorInfo.foreground": "#00000000",
        "editorHint.foreground": "#00000000"
    },
    "terminal.integrated.scrollback": 1000000,
    "terminal.integrated.confirmOnKill": "never",
    "python.terminal.activateEnvironment": false,
    "chat.disableAIFeatures": true,
    "window.density.editorTabHeight": "compact",
    "workbench.activityBar.location": "top",
    "workbench.browser.showInTitleBar": true,
    "window.commandCenter": true,
    "workbench.layoutControl.enabled": true,
    "workbench.editor.editorActionsLocation": "titleBar",
    "editor.fontSize": 16,
    "terminal.integrated.fontSize": 16,
    "workbench.colorTheme": "Solarized Light",
    "terminal.integrated.initialHint": false
}
